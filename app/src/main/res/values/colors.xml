<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 增强版 Apple TV Dark Theme Colors -->
    
    <!-- 背景层次 -->
    <color name="background_deep">#FF0A0A0C</color>
    <color name="background_primary">#FF101214</color>
    <color name="background_elevated">#FF18181B</color>
    <color name="card_background">#FF1C1C1E</color>
    <color name="card_background_hover">#FF2C2C2E</color>
    
    <!-- 渐变色 -->
    <color name="gradient_start">#FF0A84FF</color>
    <color name="gradient_end">#FF5E5CE6</color>
    <color name="gradient_accent">#FFFF6B9D</color>
    
    <!-- 主色调 -->
    <color name="primary">#FF0A84FF</color>
    <color name="primary_dark">#FF0066CC</color>
    <color name="accent">#FF5E5CE6</color>
    
    <!-- 语义色彩 -->
    <color name="rating_gold">#FFFFD60A</color>
    <color name="success_green">#FF32D74B</color>
    <color name="warning_amber">#FFFFD60A</color>
    <color name="error_red">#FFFF453A</color>
    <color name="info_blue">#FF0A84FF</color>
    
