    <color name="text_primary">#FFF5F5F7</color>
    <color name="text_secondary">#FF8E8E93</color>
    <color name="text_tertiary">#FF636366</color>
    <color name="text_disabled">#FF48484A</color>
    
    <!-- 玻璃态 -->
    <color name="glass_overlay">#40FFFFFF</color>
